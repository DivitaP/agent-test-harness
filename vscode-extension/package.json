{
  "repository": { "type": "git", "url": "https://github.com/DivitaP/agent-test-harness" },
  "license": "MIT",
  "name": "agent-harness-vscode",
  "displayName": "Agent Harness",
  "description": "Semantic testing for LangGraph agents: process, evidence, and output scorers in the Test Explorer",
  "version": "0.1.0",
  "publisher": "divita",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Testing"],
  "activationEvents": ["workspaceContains:**/*.agent-test.yaml"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "agentHarness.showTrace", "title": "Agent Harness: Show Trace" },
      { "command": "agentHarness.showSummary", "title": "Agent Harness: Show Results Summary" }
    ],
    "menus": {
      "testing/item/context": [
        { "command": "agentHarness.showSummary", "when": "controllerId == 'agentHarness'" },
        { "command": "agentHarness.showTrace", "when": "controllerId == 'agentHarness'" }
      ]
    },
    "configuration": {
      "title": "Agent Harness",
      "properties": {
        "agentHarness.command": {
          "type": "string",
          "default": "agent-harness",
          "description": "Command used to invoke the harness CLI (e.g. 'agent-harness' or 'python -m agent_harness.cli')."
        },
        "agentHarness.extraEnv": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string" },
          "description": "Extra environment variables for test runs (e.g. DEMO_FAILURE_MODE)."
        },
        "agentHarness.exclude": {
          "type": "array",
          "default": ["**/node_modules/**"],
          "items": { "type": "string" },
          "description": "Glob patterns for .agent-test.yaml suites to hide from Test Explorer."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p . --types node,vscode",
    "watch": "tsc -w -p .",
    "test": "vitest run"
  },
  "dependencies": { "yaml": "^2.4.0" },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
